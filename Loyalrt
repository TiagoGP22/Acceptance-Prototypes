<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Teya Rewards — Card Machine</title>
<link rel="stylesheet" href="colors_and_type.css" />
<style>
  html, body { margin: 0; padding: 0; min-height: 100vh; font-family: var(--font-sans); color: var(--ink);
    background:
      radial-gradient(1100px 700px at 50% -10%, #f1efe8 0%, rgba(241,239,232,0) 60%),
      #e6e3dc;
    -webkit-font-smoothing: antialiased; }
  * { box-sizing: border-box; }
  #root { min-height: 100vh; }

  @keyframes ripple { 0% { transform: scale(.42); opacity: 0; } 22% { opacity: .55; } 100% { transform: scale(1.25); opacity: 0; } }
  .ripple { position: absolute; inset: 0; border-radius: 999px; border: 3px solid currentColor; opacity: 0; animation: ripple 2.1s ease-out infinite; }
  .ripple.d1 { animation-delay: .55s; } .ripple.d2 { animation-delay: 1.1s; }

  @keyframes spin { to { transform: rotate(360deg); } }
  .spinner { animation: spin .8s linear infinite; }

  @keyframes pop { 0% { transform: scale(.5); } 62% { transform: scale(1.08); } 100% { transform: scale(1); } }
  .pop { animation: pop .5s cubic-bezier(.2,.8,.3,1.1); }

  @keyframes pulseDot { 0%,100% { box-shadow: 0 0 0 0 rgba(94,165,0,.5); } 50% { box-shadow: 0 0 0 6px rgba(94,165,0,0); } }

  @keyframes riseIn { from { transform: translateY(18px); } to { transform: translateY(0); } }
  .riseIn { animation: riseIn .55s cubic-bezier(.2,.8,.2,1); }

  @keyframes screenIn { from { transform: translateY(7px); } to { transform: translateY(0); } }
  .screenIn { animation: screenIn .3s ease; }

  @keyframes sheetUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  @keyframes scanline { 0% { top: 12%; } 50% { top: 84%; } 100% { top: 12%; } }
  .scanline { position: absolute; left: 9%; right: 9%; height: 3px; border-radius: 99px; top: 12%; opacity: .9; animation: scanline 2s ease-in-out infinite; }

  input[type=range].redeem-range { -webkit-appearance: none; appearance: none; height: 6px; border-radius: 99px; background: var(--ink-10); }
  input[type=range].redeem-range::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; width: 26px; height: 26px; border-radius: 50%; background: #fff; border: 1px solid rgba(0,0,0,.12); box-shadow: 0 2px 6px rgba(0,0,0,.25); cursor: pointer; }
  input[type=range].redeem-range::-moz-range-thumb { width: 26px; height: 26px; border-radius: 50%; background: #fff; border: 1px solid rgba(0,0,0,.12); box-shadow: 0 2px 6px rgba(0,0,0,.25); cursor: pointer; }

  ::-webkit-scrollbar { width: 0; height: 0; }
</style>
</head>
